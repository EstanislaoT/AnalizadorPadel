{
  "name": "analizador-padel-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "codegen": "openapi-typescript ./src/services/api/openapi.json --output ./src/services/api/generated/types.ts",
