{
  "openapi": "3.1.1",
  "info": {
    "title": "AnalizadorPadel.Api | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000/"
    }
  ],
  "paths": {
    "/api/videos": {
      "post": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Sube un nuevo video",
        "description": "Permite subir un archivo de video para su posterior análisis",
        "operationId": "CreateVideo",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "$ref": "#/components/schemas/IFormFile"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Lista todos los videos",
        "description": "Retorna una lista de todos los videos subidos",
        "operationId": "GetVideos",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/videos/{id}": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Obtiene un video por ID",
        "description": "Retorna los detalles de un video específico",
        "operationId": "GetVideo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Elimina un video",
        "description": "Elimina un video y sus archivos asociados",
        "operationId": "DeleteVideo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/videos/{id}/stream": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Stream de video",
        "description": "Reproduce un video con soporte para Range requests (206 Partial Content). Permite seek y descarga progresiva",
        "operationId": "StreamVideo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK - Video completo (sin Range header)",
            "headers": {
              "Accept-Ranges": {
                "schema": {
                  "type": "string"
                },
                "description": "Indica que el servidor soporta Range requests"
              },
              "Content-Type": {
                "schema": {
                  "type": "string"
                },
                "description": "Tipo MIME del video"
              },
              "Content-Length": {
                "schema": {
                  "type": "integer",
                  "format": "int64"
                },
                "description": "Tamaño total del archivo"
              }
            },
            "content": {
              "video/mp4": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "video/webm": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "206": {
            "description": "Partial Content - Fragmento del video (con Range header)",
            "headers": {
              "Accept-Ranges": {
                "schema": {
                  "type": "string"
                }
              },
              "Content-Type": {
                "schema": {
                  "type": "string"
                }
              },
              "Content-Length": {
                "schema": {
                  "type": "integer",
                  "format": "int64"
                }
              },
              "Content-Range": {
                "schema": {
                  "type": "string"
                },
                "description": "Rango enviado: bytes start-end/total"
              }
            },
            "content": {
              "video/mp4": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Video no encontrado"
          },
          "416": {
            "description": "Range Not Satisfiable - Rango inválido"
          }
        }
      }
    },
    "/api/videos/{id}/analyse": {
      "post": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Inicia el análisis de un video",
        "description": "Comienza el procesamiento del video para detectar jugadores",
        "operationId": "StartAnalysis",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/analyses/{id}": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Obtiene un análisis por ID",
        "description": "Retorna los detalles de un análisis específico",
        "operationId": "GetAnalysis",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/analyses/{id}/stats": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Obtiene estadísticas del análisis",
        "description": "Retorna las estadísticas de detección del análisis",
        "operationId": "GetAnalysisStats",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/analyses/{id}/heatmap": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Obtiene datos del heatmap",
        "description": "Retorna los datos para visualizar el heatmap de posiciones",
        "operationId": "GetAnalysisHeatmap",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/analyses/{id}/report": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Obtiene el reporte del análisis",
        "description": "Retorna la ruta del reporte PDF del análisis",
        "operationId": "GetAnalysisReport",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Health check endpoint",
        "operationId": "HealthCheck",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseOfObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/dashboard/stats": {
      "get": {
        "tags": [
          "AnalizadorPadel.Api"
        ],
        "summary": "Obtiene estadísticas del dashboard",
        "description": "Retorna las estadísticas generales del dashboard: total de videos, análisis completados, tasa de éxito, etc.",
        "operationId": "GetDashboardStats",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseOfDashboardStats"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponseOfObject": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": { }
        }
      },
      "ApiResponseOfDashboardStats": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/DashboardStats"
          }
        }
      },
      "DashboardStats": {
        "type": "object",
        "properties": {
          "totalVideos": {
            "type": "integer",
            "format": "int32"
          },
          "totalAnalyses": {
            "type": "integer",
            "format": "int32"
          },
          "completedAnalyses": {
            "type": "integer",
            "format": "int32"
          },
          "failedAnalyses": {
            "type": "integer",
            "format": "int32"
          },
          "successRatePercent": {
            "type": "number",
            "format": "double"
          },
          "avgDetectionRate": {
            "type": "number",
            "format": "double"
          },
          "recentVideos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoDto"
            }
          },
          "recentAnalyses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnalysisDto"
            }
          }
        }
      },
      "VideoDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "filePath": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["Uploaded", "Processing", "Completed", "Failed"]
          },
          "analysisId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        }
      },
      "AnalysisDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "videoId": {
            "type": "integer",
            "format": "int32"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "completedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": ["Pending", "Running", "Completed", "Failed"]
          },
          "errorMessage": {
            "type": "string",
            "nullable": true
          },
          "result": {
            "nullable": true
          }
        }
      },
      "IFormFile": {
        "type": "string",
        "format": "binary"
      }
    }
  },
  "tags": [
    {
      "name": "AnalizadorPadel.Api"
    }
  ]
}